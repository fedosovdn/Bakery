{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Catalog product"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "price": {
      "type": "decimal"
    },
    "priceOnRequest": {
      "type": "boolean",
      "default": false
    },
    "weight": {
      "type": "string"
    },
    "composition": {
      "type": "text"
    },
    "allergens": {
      "type": "text"
    },
    "shelfLife": {
      "type": "string"
    },
    "productionTime": {
      "type": "string"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "isNew": {
      "type": "boolean",
      "default": false
    },
    "isHit": {
      "type": "boolean",
      "default": false
    },
    "isAvailable": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
